# ── Alibaba Cloud ID Verification ──────────────────────────────────────────
# Get these from: Alibaba Cloud Console → top-right avatar → AccessKey Management
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# Region where your eKYC service is configured (see console tabs):
#   ap-southeast-1  = Singapore
#   ap-southeast-3  = Kuala Lumpur (Malaysia)
#   ap-southeast-5  = Jakarta (Indonesia)
#   eu-central-1    = Germany
#   us-west-1       = US Silicon Valley
#   cn-hongkong     = China Hong Kong
ALIBABA_CLOUD_REGION=ap-southeast-3

# Optional: server-side callback URL Alibaba Cloud will POST results to
ALIBABA_CALLBACK_URL=

# ── Application ─────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_EXPIRE_DAYS=7

# Must match your frontend dev URL (for CORS)
FRONTEND_URL=http://localhost:3000

# SQLite database file path (relative to backend/)
DB_PATH=users.db
